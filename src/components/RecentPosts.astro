---
import { getSanityPosts } from '../utils/getSanityPosts';

const allPosts = await getSanityPosts();
const recentPosts = allPosts
  .filter((post: any) => post?.slug?.current)
  .slice(0, 5)
  .map((post: any) => ({
    ...post,
    postUrl: `/notes/${post.slug.current}`,
  }));

const formatPostDate = (post: any) => {
  const date = post.firstPublishedAt || post.publishedAt || post._createdAt;
  const parsedDate = date ? new Date(date) : null;

  return parsedDate && !Number.isNaN(parsedDate.getTime())
    ? parsedDate.toLocaleDateString('en-US', {
        month: 'short',
        day: 'numeric',
        year: 'numeric'
      })
    : 'Unknown';
};
---

<div class="recent-posts">
  <h3>recent thoughts</h3>
  <div class="posts-list">
    {recentPosts.map((post: any) => (
      <a href={post.postUrl} class="post-link">
        <div class="post-item">
          <div class="post-title">{post.title}</div>
          <div class="post-date">
            {formatPostDate(post)}
          </div>
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  .recent-posts {
    background: var(--bg-secondary);
    border-radius: 8px;
    padding: 1.5rem;
    margin: 2rem 0;
  }

  .recent-posts h3 {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-color);
    margin: 0 0 1rem 0;
    text-transform: lowercase;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-link {
    text-decoration: none;
    color: inherit;
  }

  .post-item {
    padding: 0.75rem;
    border-radius: 6px;
    background: var(--bg-tertiary);
    transition: all 0.2s ease;
    border-left: 2px solid transparent;
  }

  .post-item:hover {
    background: var(--hover-bg);
    border-left-color: var(--text-color);
    transform: translateX(4px);
  }

  .post-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-color);
    margin-bottom: 0.25rem;
    line-height: 1.4;
  }

  .post-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-dim);
  }
</style>
