<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Comment Admin</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f7f9;
        --panel: #ffffff;
        --panel-muted: #f1f3f5;
        --text: #15171a;
        --muted: #667085;
        --line: #d9dee5;
        --line-strong: #c7ced8;
        --accent: #2563eb;
        --accent-strong: #1d4ed8;
        --success: #047857;
        --success-bg: #e6f4ef;
        --warning: #b45309;
        --warning-bg: #fff4df;
        --danger: #b42318;
        --danger-bg: #fee4e2;
        --shadow: 0 18px 45px rgba(21, 23, 26, 0.08);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      button,
      input {
        font: inherit;
      }

      button {
        cursor: pointer;
      }

      .shell {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
        padding: 32px 0 48px;
      }

      .login-wrap {
        display: grid;
        min-height: 100vh;
        place-items: center;
        padding: 24px;
      }

      .login-panel {
        width: min(100%, 420px);
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
        box-shadow: var(--shadow);
        padding: 28px;
      }

      .eyebrow {
        margin: 0 0 8px;
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1,
      h2,
      p {
        margin: 0;
      }

      .login-panel h1 {
        font-size: 1.7rem;
        line-height: 1.15;
      }

      .login-copy {
        margin-top: 10px;
        color: var(--muted);
        line-height: 1.55;
      }

      .field {
        display: grid;
        gap: 8px;
        margin-top: 24px;
      }

      .field label {
        color: #344054;
        font-size: 0.86rem;
        font-weight: 650;
      }

      .input,
      .search-input {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: #fff;
        color: var(--text);
        outline: none;
        transition:
          border-color 0.16s ease,
          box-shadow 0.16s ease;
      }

      .input {
        padding: 12px 13px;
      }

      .search-input {
        min-width: 260px;
        padding: 10px 12px;
      }

      .input:focus,
      .search-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.13);
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 24px;
      }

      .title-group h1 {
        font-size: clamp(1.8rem, 3vw, 2.55rem);
        line-height: 1.05;
        letter-spacing: 0;
      }

      .subtitle {
        margin-top: 8px;
        color: var(--muted);
        line-height: 1.45;
      }

      .actions-row,
      .toolbar,
      .card-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 40px;
        border: 1px solid transparent;
        border-radius: 8px;
        padding: 9px 14px;
        font-size: 0.9rem;
        font-weight: 700;
        transition:
          background 0.16s ease,
          border-color 0.16s ease,
          color 0.16s ease,
          transform 0.16s ease;
      }

      .button:hover:not(:disabled) {
        transform: translateY(-1px);
      }

      .button:disabled {
        cursor: not-allowed;
        opacity: 0.58;
      }

      .button.primary {
        width: 100%;
        margin-top: 18px;
        background: var(--text);
        color: #fff;
      }

      .button.blue {
        background: var(--accent);
        color: #fff;
      }

      .button.blue:hover:not(:disabled) {
        background: var(--accent-strong);
      }

      .button.ghost {
        border-color: var(--line);
        background: #fff;
        color: #344054;
      }

      .button.success {
        background: var(--success);
        color: #fff;
      }

      .button.warning {
        background: #f59e0b;
        color: #111827;
      }

      .button.danger {
        background: var(--danger);
        color: #fff;
      }

      .button.small {
        min-height: 36px;
        padding: 7px 12px;
        font-size: 0.84rem;
      }

      .error,
      .notice {
        display: none;
        border-radius: 8px;
        padding: 10px 12px;
        font-size: 0.88rem;
        line-height: 1.45;
      }

      .error {
        margin-top: 14px;
        background: var(--danger-bg);
        color: var(--danger);
      }

      .notice {
        margin-bottom: 16px;
        border: 1px solid var(--line);
        background: var(--panel);
        color: var(--muted);
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 18px;
      }

      .stat {
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
        padding: 18px;
      }

      .stat-value {
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
      }

      .stat-label {
        margin-top: 8px;
        color: var(--muted);
        font-size: 0.86rem;
        font-weight: 650;
      }

      .toolbar {
        justify-content: space-between;
        margin-bottom: 16px;
      }

      .tabs {
        display: inline-flex;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--panel);
        padding: 4px;
      }

      .filter-tab {
        min-height: 34px;
        border: 0;
        border-radius: 6px;
        background: transparent;
        color: var(--muted);
        padding: 6px 12px;
        font-size: 0.86rem;
        font-weight: 700;
      }

      .filter-tab.active {
        background: var(--text);
        color: #fff;
      }

      .comments-list {
        display: grid;
        gap: 12px;
      }

      .comment-card {
        border: 1px solid var(--line);
        border-left-width: 4px;
        border-radius: 8px;
        background: var(--panel);
        padding: 18px;
      }

      .comment-card.pending {
        border-left-color: #f59e0b;
      }

      .comment-card.approved {
        border-left-color: var(--success);
      }

      .comment-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
      }

      .comment-name {
        font-weight: 800;
      }

      .comment-email,
      .comment-meta,
      .comment-id {
        color: var(--muted);
        font-size: 0.84rem;
      }

      .comment-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
      }

      .comment-content {
        margin-top: 14px;
        color: #344054;
        line-height: 1.6;
        white-space: pre-wrap;
      }

      .badge {
        flex: 0 0 auto;
        border-radius: 999px;
        padding: 5px 10px;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
      }

      .badge.pending {
        background: var(--warning-bg);
        color: var(--warning);
      }

      .badge.approved {
        background: var(--success-bg);
        color: var(--success);
      }

      .card-actions {
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--line);
      }

      .empty,
      .loading {
        border: 1px dashed var(--line-strong);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.55);
        color: var(--muted);
        padding: 44px 20px;
        text-align: center;
      }

      @media (max-width: 760px) {
        .shell {
          width: min(100% - 24px, 1180px);
          padding-top: 20px;
        }

        .topbar,
        .toolbar {
          align-items: stretch;
          flex-direction: column;
        }

        .actions-row,
        .search-input,
        .tabs {
          width: 100%;
        }

        .tabs {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
        }

        .stats {
          grid-template-columns: 1fr;
        }

        .comment-head {
          flex-direction: column;
        }

        .card-actions .button {
          flex: 1 1 150px;
        }
      }
    </style>
  </head>
  <body>
    <main id="login-section" class="login-wrap">
      <section class="login-panel" aria-labelledby="login-title">
        <p class="eyebrow">Comment admin</p>
        <h1 id="login-title">Moderation console</h1>
        <p class="login-copy">Review pending comments and manage published replies.</p>

        <div class="field">
          <label for="admin-secret">Admin secret</label>
          <input
            id="admin-secret"
            class="input"
            type="password"
            autocomplete="current-password"
            placeholder="Enter admin secret"
          />
        </div>

        <button id="login-button" class="button primary" type="button">
          Sign in
        </button>
        <p id="login-error" class="error"></p>
      </section>
    </main>

    <main id="admin-section" class="shell" style="display: none;">
      <header class="topbar">
        <div class="title-group">
          <p class="eyebrow">Comment admin</p>
          <h1>Moderation</h1>
          <p class="subtitle" id="last-updated">Not synced yet</p>
        </div>
        <div class="actions-row">
          <button id="refresh-button" class="button ghost" type="button">Refresh</button>
          <button id="logout-button" class="button ghost" type="button">Sign out</button>
        </div>
      </header>

      <p id="notice" class="notice"></p>

      <section class="stats" aria-label="Comment summary">
        <div class="stat">
          <div class="stat-value" id="total-count">0</div>
          <div class="stat-label">Total comments</div>
        </div>
        <div class="stat">
          <div class="stat-value" id="pending-count">0</div>
          <div class="stat-label">Pending review</div>
        </div>
        <div class="stat">
          <div class="stat-value" id="approved-count">0</div>
          <div class="stat-label">Approved</div>
        </div>
      </section>

      <section class="toolbar" aria-label="Comment filters">
        <div class="tabs">
          <button class="filter-tab active" type="button" data-filter="all">
            All
          </button>
          <button class="filter-tab" type="button" data-filter="pending">
            Pending
          </button>
          <button class="filter-tab" type="button" data-filter="approved">
            Approved
          </button>
        </div>
        <input
          id="search-input"
          class="search-input"
          type="search"
          placeholder="Search name, email, post, or comment"
        />
      </section>

      <section id="comments-list" class="comments-list" aria-live="polite">
        <div class="loading">Loading comments...</div>
      </section>
    </main>

    <script is:inline>
      let adminSecret = '';
      let allComments = [];
      let currentFilter = 'all';

      function logout() {
        adminSecret = '';
        allComments = [];
        document.getElementById('login-section').style.display = 'grid';
        document.getElementById('admin-section').style.display = 'none';
        document.getElementById('admin-secret').value = '';
        document.getElementById('search-input').value = '';
        hideNotice();
      }

      async function login() {
        const secretInput = document.getElementById('admin-secret');
        const loginButton = document.getElementById('login-button');
        adminSecret = secretInput.value.trim();

        if (!adminSecret) {
          showLoginError('Enter the admin secret.');
          return;
        }

        loginButton.disabled = true;
        loginButton.textContent = 'Signing in...';

        try {
          await fetchComments();
          document.getElementById('login-section').style.display = 'none';
          document.getElementById('admin-section').style.display = 'block';
          showNotice('Signed in. Comments are up to date.');
        } catch (error) {
          showLoginError('Invalid admin secret.');
        } finally {
          loginButton.disabled = false;
          loginButton.textContent = 'Sign in';
        }
      }

      function showLoginError(message) {
        const errorEl = document.getElementById('login-error');
        errorEl.textContent = message;
        errorEl.style.display = 'block';
      }

      function showNotice(message) {
        const notice = document.getElementById('notice');
        notice.textContent = message;
        notice.style.display = 'block';
      }

      function hideNotice() {
        const notice = document.getElementById('notice');
        notice.textContent = '';
        notice.style.display = 'none';
      }

      async function fetchComments(showStatus = false) {
        if (showStatus) {
          showNotice('Refreshing comments...');
        }

        const response = await fetch('/api/admin/comments', {
          headers: {
            Authorization: `Bearer ${adminSecret}`,
          },
        });

        if (!response.ok) {
          throw new Error('Unauthorized');
        }

        const data = await response.json();
        allComments = data.comments || [];
        updateStats();
        renderComments();
        document.getElementById('last-updated').textContent =
          `Last synced ${new Date().toLocaleString()}`;

        if (showStatus) {
          showNotice('Comments refreshed.');
        }
      }

      function updateStats() {
        const total = allComments.length;
        const approved = allComments.filter((comment) => comment.approved).length;
        const pending = total - approved;

        document.getElementById('total-count').textContent = total;
        document.getElementById('pending-count').textContent = pending;
        document.getElementById('approved-count').textContent = approved;
      }

      function setFilter(filter) {
        currentFilter = filter;
        document.querySelectorAll('.filter-tab').forEach((tab) => {
          tab.classList.toggle('active', tab.dataset.filter === filter);
        });
        renderComments();
      }

      function renderComments() {
        const container = document.getElementById('comments-list');
        const searchTerm = document.getElementById('search-input').value.trim().toLowerCase();

        let filtered = allComments;
        if (currentFilter === 'pending') {
          filtered = allComments.filter((comment) => !comment.approved);
        } else if (currentFilter === 'approved') {
          filtered = allComments.filter((comment) => comment.approved);
        }

        if (searchTerm) {
          filtered = filtered.filter((comment) => {
            return [comment.name, comment.email, comment.postId, comment.content, comment.id]
              .filter(Boolean)
              .some((value) => String(value).toLowerCase().includes(searchTerm));
          });
        }

        if (filtered.length === 0) {
          container.innerHTML = '<div class="empty">No comments match this view.</div>';
          return;
        }

        container.innerHTML = filtered.map(renderCommentCard).join('');
      }

      function renderCommentCard(comment) {
        const status = comment.approved ? 'approved' : 'pending';
        const createdAt = new Date(comment.createdAt).toLocaleString();
        const email = comment.email
          ? `<div class="comment-email">${escapeHtml(comment.email)}</div>`
          : '';

        return `
          <article class="comment-card ${status}">
            <div class="comment-head">
              <div>
                <div class="comment-name">${escapeHtml(comment.name)}</div>
                ${email}
              </div>
              <span class="badge ${status}">${status}</span>
            </div>

            <div class="comment-meta">
              <span>Post: <strong>${escapeHtml(comment.postId)}</strong></span>
              <span>${createdAt}</span>
              <span class="comment-id">ID: ${escapeHtml(comment.id)}</span>
            </div>

            <div class="comment-content">${escapeHtml(comment.content)}</div>

            <div class="card-actions">
              ${comment.approved
                ? `<button class="button warning small" type="button" data-action="unapprove" data-comment-id="${escapeHtml(comment.id)}">Unapprove</button>`
                : `<button class="button success small" type="button" data-action="approve" data-comment-id="${escapeHtml(comment.id)}">Approve</button>`}
              <button class="button danger small" type="button" data-action="delete" data-comment-id="${escapeHtml(comment.id)}">Delete</button>
            </div>
          </article>
        `;
      }

      function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text || '';
        return div.innerHTML;
      }

      async function setApproval(commentId, approved) {
        try {
          const response = await fetch('/api/admin/comments', {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Authorization: `Bearer ${adminSecret}`,
            },
            body: JSON.stringify({ commentId, approved }),
          });

          if (!response.ok) {
            throw new Error('Update failed');
          }

          await fetchComments();
          showNotice(approved ? 'Comment approved.' : 'Comment moved back to pending.');
        } catch (error) {
          showNotice('Comment update failed.');
          console.error('Failed to update comment:', error);
        }
      }

      async function deleteComment(commentId) {
        if (!confirm('Delete this comment permanently?')) {
          return;
        }

        try {
          const response = await fetch('/api/admin/comments', {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json',
              Authorization: `Bearer ${adminSecret}`,
            },
            body: JSON.stringify({ commentId }),
          });

          if (!response.ok) {
            throw new Error('Delete failed');
          }

          await fetchComments();
          showNotice('Comment deleted.');
        } catch (error) {
          showNotice('Comment delete failed.');
          console.error('Failed to delete comment:', error);
        }
      }

      document.getElementById('admin-secret').addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
          login();
        }
      });

      document.getElementById('login-button').addEventListener('click', () => login());
      document.getElementById('refresh-button').addEventListener('click', () => fetchComments(true));
      document.getElementById('logout-button').addEventListener('click', () => logout());
      document.getElementById('search-input').addEventListener('input', () => renderComments());

      document.querySelectorAll('.filter-tab').forEach((tab) => {
        tab.addEventListener('click', () => {
          setFilter(tab.dataset.filter);
        });
      });

      document.getElementById('comments-list').addEventListener('click', (event) => {
        const button = event.target.closest('button[data-action]');
        if (!button) {
          return;
        }

        const commentId = button.dataset.commentId;
        if (!commentId) {
          return;
        }

        if (button.dataset.action === 'approve') {
          setApproval(commentId, true);
        } else if (button.dataset.action === 'unapprove') {
          setApproval(commentId, false);
        } else if (button.dataset.action === 'delete') {
          deleteComment(commentId);
        }
      });
    </script>
  </body>
</html>
