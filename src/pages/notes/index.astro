---
export const prerender = false;

import Header from '../../components/header/index.astro';
import '../../style/index.css';
import { getSanityPosts } from '../../utils/getSanityPosts';
import { db, views } from 'astro:db';

type Post = {
  _id?: string;
  _createdAt?: string | null;
  slug: { current: string };
  title: string;
  description?: string;
  firstPublishedAt?: string | null;
  publishedAt?: string | null;
};

const posts = await getSanityPosts() as Post[];

const getPostDateValue = (post: Post) => {
  const date = post.firstPublishedAt || post.publishedAt || post._createdAt;
  const time = date ? new Date(date).getTime() : 0;

  return Number.isNaN(time) ? 0 : time;
};

const formatPostDate = (post: Post) => {
  const date = post.firstPublishedAt || post.publishedAt || post._createdAt;
  const parsedDate = date ? new Date(date) : null;

  return parsedDate && !Number.isNaN(parsedDate.getTime())
    ? parsedDate.toLocaleDateString("en-US", { dateStyle: "long" })
    : "Unknown";
};

const sort = Astro.url.searchParams.get("sort") === "oldest" ? "oldest" : "latest";
const pageSize = 5;
const requestedPage = Number(Astro.url.searchParams.get("page") || "1");
const sortedPosts = [...posts].sort((a, b) => {
  return sort === "oldest"
    ? getPostDateValue(a) - getPostDateValue(b)
    : getPostDateValue(b) - getPostDateValue(a);
});
const totalPages = Math.max(1, Math.ceil(sortedPosts.length / pageSize));
const currentPage = Math.min(Math.max(Number.isNaN(requestedPage) ? 1 : requestedPage, 1), totalPages);
const paginatedPosts = sortedPosts.slice((currentPage - 1) * pageSize, currentPage * pageSize);
const pageNumbers = Array.from({ length: totalPages }, (_, index) => index + 1);
const getPageHref = (page: number) => {
  const params = new URLSearchParams();

  if (sort !== "latest") {
    params.set("sort", sort);
  }

  if (page > 1) {
    params.set("page", String(page));
  }

  const query = params.toString();
  return query ? `/notes?${query}` : "/notes";
};

const allViews = await db.select().from(views);

const viewCounts: Record<string, number> = {};

allViews.forEach(v => {
  viewCounts[v.postId] = (viewCounts[v.postId] || 0) + 1;
});
---

