          {pageNumbers.map((page) => (
            page === currentPage ? (
              <span class="rounded bg-default px-3 py-1.5 text-white" aria-current="page">
                {page}
              </span>
            ) : (
              <a href={getPageHref(page)} class="rounded px-3 py-1.5 text-default hover:underline">
                {page}
              </a>
            )
          ))}

          {currentPage < totalPages ? (
            <a href={getPageHref(currentPage + 1)} class="rounded px-3 py-1.5 text-default hover:underline">Next →</a>
          ) : (
            <span class="rounded px-3 py-1.5 text-gray-400">Next →</span>
