                  </span>
                  <span>{commentsCount}</span>
                </span>
              </div> */}
            </div>
          </div>
        );
      })}
    </div>

    {totalPages > 1 && (
      <nav class="mt-10 flex flex-wrap items-center justify-between gap-4 text-sm" aria-label="Notes pagination">
        <div class="text-gray-500">
          Page {currentPage} of {totalPages}
