        <div class="flex flex-wrap items-center gap-2">
          {currentPage > 1 ? (
            <a href={getPageHref(currentPage - 1)} class="rounded px-3 py-1.5 text-default hover:underline">← Previous</a>
          ) : (
            <span class="rounded px-3 py-1.5 text-gray-400">← Previous</span>
