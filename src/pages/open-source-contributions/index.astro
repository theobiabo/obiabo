---
import Header from '../../components/header/index.astro'
import SEO from '../../components/seo/index.astro'
import '../../style/index.css'
import { getSanityOpenSourceContributions } from '../../utils/getSanityOpenSourceContributions'

const page = await getSanityOpenSourceContributions()
const title = page?.title ?? 'Open Source Contributions'
const overviewTitle = page?.overviewTitle
const overviewText = page?.overviewText
const contributionsTitle = page?.contributionsTitle
const contributionGroups = page?.groups ?? []
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <SEO title={title} description={overviewText || 'Open source contributions by Emmanuel Obiabo.'} />
</head>
<body>
    <Header title={title} />
    <main class="page-shell">
        {overviewTitle && overviewText && (
            <section class="mb-12">
                <h2 class="text-md font-semibold mb-4">{overviewTitle}</h2>
                <p class="leading-relaxed text-sm">
                    {overviewText}
                </p>
            </section>
        )}

        <section class="mb-12">
            {contributionsTitle && (
                <h2 class="text-lg font-semibold mb-6">{contributionsTitle}</h2>
            )}

            {contributionGroups.length > 0 ? (
                <div class="space-y-8">
                    {contributionGroups.map((group) => (
                        <div class="text-default">
                            <h3 class="text-md font-medium mb-3 text-default">{group.projectName}</h3>
                            {group.description && <p class="mb-4 text-sm">{group.description}</p>}
                            {group.items && group.items.length > 0 && (
                                <ul class="space-y-2 text-sm">
                                    {group.items.map((item) => (
                                        <li>
                                            <a href={item.url} class="text-blue-600 hover:underline" target="_blank" rel="noreferrer">
                                                {item.title}
                                            </a>
                                            {' - '}{item.description}
                                        </li>
                                    ))}
                                </ul>
                            )}
                        </div>
                    ))}
                </div>
            ) : (
                <p class="text-sm text-gray-500">No open source contributions have been added in the CMS yet.</p>
            )}
        </section>
    </main>
</body>
</html>
